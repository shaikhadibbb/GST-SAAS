# ============================================
# GST Compliance SaaS — Environment Variables
# Copy this file to .env and fill in real values
# Run: node generate-secrets.js for JWT secrets
# ============================================

# ─── App ─────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/gst_saas_db?schema=public

# ─── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SECONDS=300

# ─── JWT (generate with: node generate-secrets.js) ──
JWT_SECRET=your-256-bit-secret-here-change-in-production-min-64-chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=different-256-bit-secret-here-change-in-production-min-64
JWT_REFRESH_EXPIRES_IN=7d
# AI Features
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── CORS ────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# ─── Rate Limiting ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ─── Bcrypt ──────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Email (Gmail SMTP) ──────────────────────
# For Gmail: enable 2FA, generate App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
